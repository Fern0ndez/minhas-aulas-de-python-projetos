import copy

banco_tarefas = {
    "tarefas": []
}

STATUS_VALIDOS = ("pendente", "em andamento", "concluido")


def criar_tarefa(descricao, status="pendente", *tags):
    if status not in STATUS_VALIDOS:
        raise ValueError("Status inválido")

    palavras = descricao.split()
    return {
        "descricao": " ".join(palavras),
        "status": status,
        "tags": list(tags)
    }


def adicionar_tarefa(banco, tarefa):
    banco["tarefas"].append(tarefa)


def listar_tarefas(banco):
    if not banco["tarefas"]:
        print("Nenhuma tarefa cadastrada.")
        return

    for i, t in enumerate(banco["tarefas"]):
        print(f"{i}. {t['descricao']} [{t['status']}] ({', '.join(t['tags'])})")


def atualizar_status(banco, indice, novo_status):
    if novo_status not in STATUS_VALIDOS:
        print("Status inválido!")
        return

    try:
        banco["tarefas"][indice]["status"] = novo_status
        print("Status atualizado!")
    except:
        print("Índice inválido!")


def filtrar_tarefas(banco):
    status = input("Digite o status para filtrar: ")

    resultado = list(filter(lambda t: t["status"] == status, banco["tarefas"]))

    for t in resultado:
        print(f"- {t['descricao']}")


def menu():
    print("\n===== MENU =====")
    print("1 - Adicionar tarefa")
    print("2 - Listar tarefas")
    print("3 - Atualizar status")
    print("4 - Filtrar tarefas")
    print("5 - Sair")


def main():
    while True:
        menu()
        opcao = input("Escolha uma opção: ")

        if opcao == "1":
            desc = input("Descrição: ")
            status = input("Status (pendente/em andamento/concluido): ")
            tags = input("Tags (separadas por espaço): ").split()

            tarefa = criar_tarefa(desc, status, *tags)
            adicionar_tarefa(banco_tarefas, tarefa)

        elif opcao == "2":
            listar_tarefas(banco_tarefas)

        elif opcao == "3":
            listar_tarefas(banco_tarefas)
            i = int(input("Número da tarefa: "))
            novo = input("Novo status: ")
            atualizar_status(banco_tarefas, i, novo)

        elif opcao == "4":
            filtrar_tarefas(banco_tarefas)

        elif opcao == "5":
            print("Saindo...")
            break

        else:
            print("Opção inválida!")


if __name__ == "__main__":
    main()